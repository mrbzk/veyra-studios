# Veyra Studios — Agent Environment Variables
# ================================================
# Complete this file before deploying to Railway.
# Never commit this file to GitHub — it is in .gitignore.
# Add each variable to Railway dashboard under
# Settings → Variables after deployment.
#
# HOW TO GET EACH KEY — see notes below each variable.
# ================================================


# ── ANTHROPIC ────────────────────────────────────────────
# Used by both agents to call Claude claude-sonnet-4-6.
# Get from: https://console.anthropic.com → API Keys
# Format: sk-ant-api03-...

ANTHROPIC_API_KEY=


# ── STRIPE ───────────────────────────────────────────────
# Webhook secret for verifying Stripe events are genuine.
# Get from: Stripe Dashboard → Developers → Webhooks
# → Add endpoint → https://[your-railway-url]/stripe-webhook
# → Select event: customer.created
# → Click endpoint → Reveal signing secret
# Format: whsec_...

STRIPE_WEBHOOK_SECRET=


# ── FRAME.IO ─────────────────────────────────────────────
# API key for reading project status and getting review links.
# Get from: https://developer.frame.io → Apps → New App
# → Generate token with scopes:
#   asset.read, project.read, project.create,
#   review_link.read, team.read

FRAMEIO_API_KEY=

# Webhook secret for verifying Frame.io events are genuine.
# Get from: Frame.io Developer → Apps → Your App → Webhooks
# → Add endpoint → https://[your-railway-url]/frameio-webhook
# → Select events: project.status_updated, review_link.approved
# → Copy the secret token shown after creation

FRAMEIO_WEBHOOK_SECRET=


# ── NOTION ───────────────────────────────────────────────
# Integration token for reading and writing Notion databases.
# Get from: https://www.notion.so/my-integrations
# → New integration → Veyra Agent
# → Copy Internal Integration Token
# → Share each database with the integration:
#   Open Client DB → ... → Connections → Veyra Agent
#   Open Project Tracker → ... → Connections → Veyra Agent
#   Open Script & Board Library → ... → Connections → Veyra Agent
# Format: secret_...

NOTION_API_KEY=


# ── SLACK ────────────────────────────────────────────────
# Bot token for creating channels, inviting guests, posting.
# Get from: https://api.slack.com/apps → Create New App
# → From Scratch → Name: Veyra Agent → Your workspace
# → OAuth & Permissions → Add Bot Token Scopes:
#
#   REQUIRED SCOPES:
#   channels:manage        create and archive channels
#   channels:join          join channels
#   channels:read          list and search channels
#   chat:write             post messages
#   groups:write           create private channels
#   users:read             look up user profiles
#   users:read.email       find users by email address
#
#   REQUIRED FOR GUEST INVITES:
#   channels:write         invite external guests
#
#   NOTE ON GUEST INVITES:
#   Single-channel guest invites use the
#   conversations.inviteShared API endpoint.
#   This requires your Slack workspace to be on a
#   Pro plan or above. Free workspaces do not support
#   external guest invitations.
#   If on a free plan, the agent will log a warning
#   and post a manual invite alert to #production.
#
# → Install App → Copy Bot User OAuth Token
# Format: xoxb-...

SLACK_BOT_TOKEN=

# Your Slack user ID — the agent invites you to every
# new client channel automatically.
# Get from: Slack → Click your name → Profile
# → ··· → Copy member ID
# Format: U0XXXXXXX

SLACK_ADMIN_USER_ID=


# ── NOTION DATABASE IDs ──────────────────────────────────
# These are already set — do not change unless you
# recreate the databases.

NOTION_CLIENT_DB_ID=36d8e2ee-ae0c-8028-a00b-f15951998479
NOTION_PROJECT_TRACKER_ID=36d8e2ee-ae0c-80f4-9158-fffc22de55e2


# ── SLACK CHANNELS ───────────────────────────────────────
# Internal channel where production alerts are posted.
# Create this channel in Slack first then paste the name.
# Do not include the # symbol.

INTERNAL_SLACK_CHANNEL=production


# ── SERVER ───────────────────────────────────────────────
# Railway sets PORT automatically — leave as 3000 locally.

PORT=3000


# ── ONBOARDING FORM ──────────────────────────────────────
# The URL sent to clients in the welcome Slack message.

ONBOARDING_FORM_URL=https://veyrastudios.eu


# ================================================
# RAILWAY DEPLOYMENT CHECKLIST
# ================================================
#
# 1. Push code to GitHub
# 2. Go to railway.app → New Project → GitHub repo
# 3. Railway auto-deploys — gives you a URL:
#    https://veyra-agent-production.up.railway.app
# 4. Go to project → Settings → Variables
# 5. Add every variable above
# 6. Stripe → Developers → Webhooks:
#    Add: https://[railway-url]/stripe-webhook
#    Event: customer.created
#    Copy signing secret → STRIPE_WEBHOOK_SECRET
# 7. Frame.io Developer → Webhooks:
#    Add: https://[railway-url]/frameio-webhook
#    Events: project.status_updated, review_link.approved
#    Copy secret → FRAMEIO_WEBHOOK_SECRET
# 8. Redeploy Railway after adding all variables
# 9. Test: GET https://[railway-url]/health
#    Should return: { "status": "ok" }
# 10. Test Stripe in test mode with a test customer.created
#
# ================================================
# FUTURE MIGRATION TO REACT HOSTING
# See: MIGRATION-NOTES.md
# ================================================
